{
  "name": "crochet-flow",
  "version": "1.0.0",
  "description": "코니 — 코바늘·대바늘 도안 제작 앱 (Crochet Flow)",
  "private": true,
  "scripts": {
    "serve": "npx serve . -l 3940",
    "web:build": "node -e \"const fs=require('fs'),p=require('path');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist/icons',{recursive:true});['index.html','manifest.json','sw.js'].forEach(f=>fs.existsSync(f)&&fs.copyFileSync(f,p.join('dist',f)));if(fs.existsSync('icons'))fs.readdirSync('icons').filter(f=>/\\.(png|ico|svg)$/.test(f)).forEach(f=>fs.copyFileSync(p.join('icons',f),p.join('dist/icons',f)));console.log('dist/ 빌드 완료:',fs.readdirSync('dist'));\"",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:build:android": "npx cap build android",
    "cap:build:ios": "npx cap build ios",
    "ext:build": "node -e \"const fs=require('fs');fs.mkdirSync('chrome-ext/app',{recursive:true});fs.copyFileSync('index.html','chrome-ext/app/index.html');console.log('Chrome Extension: chrome-ext/app/index.html 복사 완료');\""
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "serve": "^14.0.0"
  }
}
